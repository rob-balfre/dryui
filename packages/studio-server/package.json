{
  "name": "@dryui/studio-server",
  "version": "0.0.1",
  "author": "Rob Balfre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-balfre/dryui.git",
    "directory": "packages/studio-server"
  },
  "homepage": "https://github.com/rob-balfre/dryui#readme",
  "bugs": {
    "url": "https://github.com/rob-balfre/dryui/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "default": "./dist/protocol.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./command-parser": {
      "types": "./dist/command-parser.d.ts",
      "default": "./dist/command-parser.js"
    },
    "./session-store": {
      "types": "./dist/session-store.d.ts",
      "default": "./dist/session-store.js"
    },
    "./pty-manager": {
      "types": "./dist/pty-manager.d.ts",
      "default": "./dist/pty-manager.js"
    },
    "./ws-gateway": {
      "types": "./dist/ws-gateway.d.ts",
      "default": "./dist/ws-gateway.js"
    },
    "./system-prompt": {
      "types": "./dist/system-prompt.d.ts",
      "default": "./dist/system-prompt.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun src/dev.ts",
    "build": "bun build src/index.ts src/protocol.ts src/types.ts src/command-parser.ts src/session-store.ts src/pty-manager.ts src/ws-gateway.ts src/system-prompt.ts --outdir dist --target node",
    "check": "bunx tsc -p ./tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
