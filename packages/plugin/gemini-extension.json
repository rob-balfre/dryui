{
  "name": "dryui",
  "version": "0.3.0",
  "description": "DryUI component library — Svelte 5 guidance, bootstrap, live feedback, and MCP servers",
  "mcpServers": {
    "dryui": {
      "command": "sh",
      "args": ["-c", "cd \"${TMPDIR:-/tmp}\" && exec npx -y @dryui/mcp"]
    },
    "dryui-feedback": {
      "command": "sh",
      "args": ["-c", "cd \"${TMPDIR:-/tmp}\" && exec npx -y -p @dryui/feedback-server dryui-feedback-mcp"]
    }
  },
  "contextFileName": "GEMINI.md"
}
