{
  "name": "@dryui/lint",
  "description": "Svelte preprocessor that enforces DryUI layout, markup, and CSS rules.",
  "version": "0.5.0",
  "author": "Rob Balfre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-balfre/dryui.git",
    "directory": "packages/lint"
  },
  "homepage": "https://github.com/rob-balfre/dryui#readme",
  "bugs": {
    "url": "https://github.com/rob-balfre/dryui/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./rule-catalog": {
      "types": "./dist/rule-catalog.d.ts",
      "bun": "./src/rule-catalog.ts",
      "default": "./dist/rule-catalog.js"
    },
    "./rules": {
      "types": "./dist/rules.d.ts",
      "bun": "./src/rules.ts",
      "default": "./dist/rules.js"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "devDependencies": {
    "svelte": "^5.55.4",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
