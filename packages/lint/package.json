{
  "name": "@dryui/lint",
  "description": "Svelte preprocessor that enforces DryUI layout, markup, and CSS rules.",
  "version": "0.7.1",
  "author": "Rob Balfre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-balfre/dryui.git",
    "directory": "packages/lint"
  },
  "homepage": "https://github.com/rob-balfre/dryui#readme",
  "bugs": {
    "url": "https://github.com/rob-balfre/dryui/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./rule-catalog": {
      "types": "./dist/rule-catalog.d.ts",
      "bun": "./src/rule-catalog.ts",
      "default": "./dist/rule-catalog.js"
    },
    "./rules": {
      "types": "./dist/rules.d.ts",
      "bun": "./src/rules.ts",
      "default": "./dist/rules.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "bun test src",
    "check:publint": "publint",
    "check:attw": "attw --pack . --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "check:publish-hygiene": "bun run check:publint && bun run check:attw"
  },
  "devDependencies": {
    "svelte": "^5.55.5",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
