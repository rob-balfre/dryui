{
  "name": "@dryui/feedback",
  "version": "1.0.0",
  "author": "Rob Balfre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-balfre/dryui.git",
    "directory": "packages/feedback"
  },
  "homepage": "https://github.com/rob-balfre/dryui#readme",
  "bugs": {
    "url": "https://github.com/rob-balfre/dryui/issues"
  },
  "type": "module",
  "sideEffects": false,
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "svelte": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "svelte-package -i src",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:publint": "publint",
    "check:attw": "attw --pack . --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "check:publish-hygiene": "bun run check:publint && bun run check:attw"
  },
  "dependencies": {
    "@dryui/primitives": "^3.0.0",
    "@dryui/ui": "^3.0.0"
  },
  "peerDependencies": {
    "svelte": "^5.55.5",
    "lucide-svelte": ">=1.0.1"
  },
  "peerDependenciesMeta": {},
  "devDependencies": {
    "svelte": "^5.55.5",
    "@sveltejs/package": "^2.5.7",
    "svelte-check": "^4.4.7",
    "typescript": "^6.0.3"
  }
}
