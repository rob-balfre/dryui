{
  "name": "@dryui/mcp",
  "version": "3.0.0",
  "author": "Rob Balfre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-balfre/dryui.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/rob-balfre/dryui#readme",
  "bugs": {
    "url": "https://github.com/rob-balfre/dryui/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dryui-mcp": "./bin/dryui-mcp.mjs"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./architecture": {
      "bun": "./src/architecture.ts",
      "types": "./dist/architecture.d.ts",
      "default": "./dist/architecture.js"
    },
    "./theme-checker": {
      "bun": "./src/theme-checker.ts",
      "types": "./dist/theme-checker.d.ts",
      "default": "./dist/theme-checker.js"
    },
    "./agent-contract": {
      "bun": "./src/agent-contract.ts",
      "types": "./dist/agent-contract.d.ts",
      "default": "./dist/agent-contract.js"
    },
    "./agent-drift": {
      "bun": "./src/agent-drift.ts",
      "types": "./dist/agent-drift.d.ts",
      "default": "./dist/agent-drift.js"
    },
    "./repair": {
      "bun": "./src/repair.ts",
      "types": "./dist/repair.d.ts",
      "default": "./dist/repair.js"
    },
    "./define": {
      "bun": "./src/define.ts",
      "types": "./dist/define.d.ts",
      "default": "./dist/define.js"
    },
    "./docs-surface": {
      "bun": "./src/docs-surface.ts",
      "types": "./dist/docs-surface.d.ts",
      "default": "./dist/docs-surface.js"
    },
    "./agent-contract.v1.json": {
      "bun": "./src/agent-contract.v1.json",
      "default": "./dist/agent-contract.v1.json"
    },
    "./agent-contract.v1.schema.json": {
      "bun": "./src/agent-contract.v1.schema.json",
      "default": "./dist/agent-contract.v1.schema.json"
    },
    "./contract.v1.json": "./dist/contract.v1.json",
    "./contract.v1.schema.json": "./dist/contract.v1.schema.json",
    "./spec": "./dist/spec.json",
    "./spec.json": {
      "bun": "./src/spec.json",
      "default": "./dist/spec.json"
    },
    "./architecture.json": "./dist/architecture.json",
    "./composition-data": {
      "bun": "./src/composition-data.ts",
      "types": "./dist/composition-data.d.ts",
      "default": "./dist/composition-data.js"
    },
    "./spec-types": {
      "bun": "./src/spec-types.ts",
      "types": "./dist/spec-types.d.ts",
      "default": "./dist/spec-types.js"
    },
    "./spec-formatters": {
      "bun": "./src/spec-formatters.ts",
      "types": "./dist/spec-formatters.d.ts",
      "default": "./dist/spec-formatters.js"
    },
    "./toon": {
      "bun": "./src/toon.ts",
      "types": "./dist/toon.d.ts",
      "default": "./dist/toon.js"
    },
    "./composition-search": {
      "bun": "./src/composition-search.ts",
      "types": "./dist/composition-search.d.ts",
      "default": "./dist/composition-search.js"
    },
    "./tokens": {
      "bun": "./src/tokens.ts",
      "types": "./dist/tokens.d.ts",
      "default": "./dist/tokens.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./architecture": {
        "types": "./dist/architecture.d.ts",
        "default": "./dist/architecture.js"
      },
      "./theme-checker": {
        "types": "./dist/theme-checker.d.ts",
        "default": "./dist/theme-checker.js"
      },
      "./agent-contract": {
        "types": "./dist/agent-contract.d.ts",
        "default": "./dist/agent-contract.js"
      },
      "./agent-drift": {
        "types": "./dist/agent-drift.d.ts",
        "default": "./dist/agent-drift.js"
      },
      "./repair": {
        "types": "./dist/repair.d.ts",
        "default": "./dist/repair.js"
      },
      "./define": {
        "types": "./dist/define.d.ts",
        "default": "./dist/define.js"
      },
      "./docs-surface": {
        "types": "./dist/docs-surface.d.ts",
        "default": "./dist/docs-surface.js"
      },
      "./agent-contract.v1.json": "./dist/agent-contract.v1.json",
      "./agent-contract.v1.schema.json": "./dist/agent-contract.v1.schema.json",
      "./contract.v1.json": "./dist/contract.v1.json",
      "./contract.v1.schema.json": "./dist/contract.v1.schema.json",
      "./spec": "./dist/spec.json",
      "./spec.json": "./dist/spec.json",
      "./architecture.json": "./dist/architecture.json",
      "./composition-data": {
        "types": "./dist/composition-data.d.ts",
        "default": "./dist/composition-data.js"
      },
      "./spec-types": {
        "types": "./dist/spec-types.d.ts",
        "default": "./dist/spec-types.js"
      },
      "./spec-formatters": {
        "types": "./dist/spec-formatters.d.ts",
        "default": "./dist/spec-formatters.js"
      },
      "./toon": {
        "types": "./dist/toon.d.ts",
        "default": "./dist/toon.js"
      },
      "./composition-search": {
        "types": "./dist/composition-search.d.ts",
        "default": "./dist/composition-search.js"
      },
      "./tokens": {
        "types": "./dist/tokens.d.ts",
        "default": "./dist/tokens.js"
      }
    }
  },
  "scripts": {
    "generate-spec": "bun src/generate-spec.ts",
    "generate-architecture": "bun src/generate-architecture.ts",
    "generate-contract": "bun src/generate-contract.ts",
    "generate-agent-contract": "bun src/generate-agent-contract.ts",
    "generate-llms": "bun src/generate-llms-txt.ts",
    "generate-theme-tokens": "bun src/generate-theme-tokens.ts",
    "check:contract": "bun src/check-contract.ts",
    "check:agent-contract": "bun src/check-agent-contract.ts",
    "check:types": "tsc -p tsconfig.json --noEmit",
    "check": "bun run check:contract && bun run check:agent-contract && bun run check:types",
    "test": "cd ../.. && bun run --filter '@dryui/mcp' generate-spec && bun test packages/mcp/src",
    "postinstall": "node -e \"try{require('fs').chmodSync(require('path').join(__dirname,'dist','index.js'),0o755)}catch{}\"",
    "build": "bun run generate-spec && (bun run generate-architecture & bun run generate-contract & bun run generate-agent-contract & bun run generate-llms & bun run generate-theme-tokens & wait) && mkdir -p dist && cp src/spec.json dist/spec.json && cp src/architecture.json dist/architecture.json && cp src/contract.v1.json dist/contract.v1.json && cp src/contract.v1.schema.json dist/contract.v1.schema.json && cp src/agent-contract.v1.json dist/agent-contract.v1.json && cp src/agent-contract.v1.schema.json dist/agent-contract.v1.schema.json && cp src/theme-tokens.generated.json dist/theme-tokens.generated.json && bun build src/index.ts src/architecture.ts src/agent-contract.ts src/agent-drift.ts src/theme-checker.ts src/utils.ts src/spec-types.ts src/spec-formatters.ts src/composition-data.ts src/toon.ts src/composition-search.ts src/tokens.ts src/repair.ts src/define.ts src/docs-surface.ts --outdir dist --root src --target node && printf '#!/usr/bin/env node\n' | cat - dist/index.js > dist/index.tmp && mv dist/index.tmp dist/index.js && chmod +x dist/index.js && bunx tsc -p tsconfig.build.json",
    "prepack": "bun ../../scripts/prepack-exports.ts",
    "postpack": "bun ../../scripts/postpack-exports.ts",
    "check:publint": "publint",
    "check:attw": "attw --pack . --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "check:publish-hygiene": "bun run check:publint && bun run check:attw"
  },
  "dependencies": {
    "@dryui/lint": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
