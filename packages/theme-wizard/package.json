{
  "name": "@dryui/theme-wizard",
  "version": "16.0.0",
  "author": "Rob Balfre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-balfre/dryui.git",
    "directory": "packages/theme-wizard"
  },
  "homepage": "https://github.com/rob-balfre/dryui#readme",
  "bugs": {
    "url": "https://github.com/rob-balfre/dryui/issues"
  },
  "type": "module",
  "sideEffects": false,
  "svelte": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./engine": {
      "types": "./src/engine/index.ts",
      "default": "./src/engine/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "svelte": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "svelte": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./engine": {
        "types": "./dist/engine/index.d.ts",
        "default": "./dist/engine/index.js"
      }
    }
  },
  "scripts": {
    "build": "svelte-package -i src",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "prepack": "bun ../../scripts/prepack-exports.ts",
    "postpack": "bun ../../scripts/postpack-exports.ts",
    "check:publint": "publint",
    "check:attw": "attw --pack . --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "check:publish-hygiene": "bun run check:publint && bun run check:attw"
  },
  "peerDependencies": {
    "@dryui/primitives": "^3.0.0",
    "@dryui/ui": "^3.0.0",
    "lucide-svelte": ">=1.0.1",
    "svelte": "^5.55.5"
  },
  "devDependencies": {
    "@dryui/lint": "workspace:*",
    "@dryui/primitives": "workspace:*",
    "@dryui/ui": "workspace:*",
    "svelte": "^5.55.5",
    "@sveltejs/package": "^2.5.7",
    "svelte-check": "^4.4.6",
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
