{
  "name": "@dryui/cli",
  "version": "0.18.0",
  "author": "Rob Balfre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-balfre/dryui.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/rob-balfre/dryui#readme",
  "bugs": {
    "url": "https://github.com/rob-balfre/dryui/issues"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "dryui": "./dist/index.js"
  },
  "scripts": {
    "build": "bun run --filter '@dryui/mcp' generate-spec && bun build src/index.ts --outdir dist --target node --external playwright",
    "check:publint": "publint",
    "check:attw": "attw --pack . --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "check:publish-hygiene": "bun run check:publint && bun run check:attw"
  },
  "dependencies": {
    "@dryui/feedback-server": "^0.8.2",
    "@dryui/mcp": "^2.6.0",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
