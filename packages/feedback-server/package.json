{
  "name": "@dryui/feedback-server",
  "version": "0.8.3",
  "author": "Rob Balfre",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rob-balfre/dryui.git",
    "directory": "packages/feedback-server"
  },
  "homepage": "https://github.com/rob-balfre/dryui#readme",
  "bugs": {
    "url": "https://github.com/rob-balfre/dryui/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dryui-feedback-mcp": "./dist/mcp.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "default": "./dist/mcp.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./internals/probe": {
      "types": "./dist/config-probe.d.ts",
      "default": "./dist/config-probe.js"
    }
  },
  "files": [
    "dist",
    "hooks"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "mkdir -p dist && bun build src/index.ts src/mcp.ts src/config-probe.ts --outdir dist --root src --target node && bun build src/server.ts --outdir dist --root src --target bun && printf '#!/usr/bin/env node\n' | cat - dist/mcp.js > dist/mcp.tmp && mv dist/mcp.tmp dist/mcp.js && chmod +x dist/mcp.js && tsc -p tsconfig.build.json && vite build --config ui/vite.config.ts",
    "check": "svelte-check --tsconfig ./ui/tsconfig.json && tsc -p tsconfig.json --noEmit",
    "test": "bun test tests",
    "check:publint": "publint",
    "check:attw": "attw --pack . --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "check:publish-hygiene": "bun run check:publint && bun run check:attw"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dryui/primitives": "workspace:*",
    "@dryui/ui": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.6.0",
    "bun-types": "^1.3.13",
    "lucide-svelte": ">=1.0.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
