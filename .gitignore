# Generated analysis artifacts live here when scripts are run locally.
reports/architecture-audit.md

# Local scratch dirs — ignore contents but keep the top-level README so future
# contributors can see what each one is for. Git refuses to un-ignore files
# inside a fully-ignored directory, so we ignore each dir's children instead.
test-projects/*
!test-projects/README.md
theme-inspo/*
!theme-inspo/README.md
diagram-samples/*
!diagram-samples/README.md
vendor/*
!vendor/README.md

# Auto-generated .d.ts emitted into package src/ dirs when svelte-package
# walks workspace paths (the real published .d.ts files live in dist/).
# Hand-written shims like tour-root.css.d.ts stay tracked via !-negation below.
packages/*/src/**/*.svelte.d.ts
packages/*/src/**/index.d.ts
packages/*/src/**/*.d.ts
!packages/ui/src/tour/tour-root.css.d.ts
