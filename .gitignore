# TypeScript incremental build cache — per-package and root.
*.tsbuildinfo
# Generated analysis artifacts live here when scripts are run locally.
reports/architecture-audit.md
# Local sandbox for trying out code-quality / dead-code / cycle tools.
.analysis/

# Local scratch dirs — ignore contents but keep the top-level README so future
# contributors can see what each one is for. Git refuses to un-ignore files
# inside a fully-ignored directory, so we ignore each dir's children instead.
test-projects/*
!test-projects/README.md
theme-inspo/*
!theme-inspo/README.md
diagram-samples/*
!diagram-samples/README.md
vendor/*
!vendor/README.md

# Auto-generated .d.ts emitted into package src/ dirs when svelte-package
# walks workspace paths (the real published .d.ts files live in dist/).
# Hand-written shims like tour-root.css.d.ts stay tracked via !-negation below.
packages/*/src/**/*.svelte.d.ts
packages/*/src/**/index.d.ts
packages/*/src/**/*.d.ts
!packages/ui/src/area-grid/area-grid-root.css.d.ts
!packages/ui/src/tour/tour-root.css.d.ts

# Benchmark run artifacts (large, per-run, regenerable)
reports/benchmarks/artifacts/
!reports/benchmarks/artifacts/.gitkeep

# Benchmark run outputs — regenerated on every validate/bench:smoke run.
# Keep `baseline.json` tracked so regression gates have a stable target.
reports/benchmarks/latest.json
reports/benchmarks/latest.md
reports/benchmarks/history/*.jsonl
!reports/benchmarks/history/.gitkeep

# E2E harness outputs — tarballs are per-run and logs are throwaway artifacts.
reports/e2e-tarballs/
reports/e2e-runs/
