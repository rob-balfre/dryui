# Auto-generated .d.ts emitted into package src/ dirs when svelte-package
# walks workspace paths (the real published .d.ts files live in dist/).
# Hand-written shims like tour-root.css.d.ts stay tracked via !-negation below.
packages/*/src/**/*.svelte.d.ts
packages/*/src/**/index.d.ts
packages/*/src/**/*.d.ts
!packages/ui/src/tour/tour-root.css.d.ts
